@startuml
title Cancer data evolution – Evidence + Follow-up Visit (Disease Evolution - Recurrence) + Second Treatment (Date 7 - 9)

skinparam class {
  BackgroundColor White
}
scale 0.8

package "Date 0 (2018-05-01)\nCancer Condition Diagnosis" {
  class CancerPatient1 <<fixed>> {
    demographics
    comorbiditiesAtDiagnosis
  }
  
  class CancerConditionAtDiagnosis1 <<fixed>> {
    tumourGrade = XXX
    histologyBehaviour = XXX
    bodySite = XXX
    visitDate 
    biopsyDate 
    labReportDate[biomarker] 
    ImagingDate = 2018-05-01 'Date 0
  }
 
}

' Links inside Date 0
CancerPatient1 --> CancerConditionAtDiagnosis1 : is affected by

 package "Date 7 (2019-08-31) \nEvidence + Follow-up (Recurrence)" {
    
    class LastFollowUp4 {
     vitalStatus = Alive
     evidenceOfDisease = Yes
     causeOfDeath = Null
     deathDate = Null
     date = 2019-08-31   'Date 7
  }

    class ClinicalCancerProgression4 {
      diseaseStatus = Recurrence
      extentType 
      loco-regionalSite 
      MetastaticSite 
      tumourGrade
      assertedDate = 2019-08-31   'Date 7
    }

 }

CancerPatient1 --> LastFollowUp4 : has
CancerConditionAtDiagnosis1 --> ClinicalCancerProgression4 : evolves throught


package "Date 8 (2019-09-10) - Date 9 (2019-12-16)\n Cancer Treatment 2" {
    
    class SystemicTreatment1 {
      intent = Definitive
      settings = Alone
      type
      ongoning = Null
      startDate = 2019-09-10   'Date 8
      endDate = 2019-12-16   'Date 9
    }

 }

CancerConditionAtDiagnosis1 --> SystemicTreatment1 : is the target of
ClinicalCancerProgression4 --> SystemicTreatment1 : is the target of
/' ' ===========================================
'Date 7 – 2019-08-31 (Disease Evolution + Follow-up)
' ===========================================
package date7 as "Date 7 (2019-08-31)\nEvidence + Follow-up (Disease Evolution)" {

  class CancerCondition_D7 as "Cancer Condition" {
    histology_behaviour (fixed)
    body_site (fixed)
    tumour_grade
    asserted_date = procedure date (fixed)
    base_of_diagnosis (fixed)
    imaging_type (fixed)
    biomarker_type (fixed)
    disease_status = Recurrence
    last_check = 2019-08-31
  }

  class DiseaseEvolution1 as "Disease Evolution (over time & space) 1" {
    extent_type = Recurrence
    disease_extent (sites)
    histology_behaviour
    tumour_grade
    base_of_diagnosis (fixed)
    imaging_type (fixed)
    biomarker_type (fixed)
    genomics
    asserted_date = 2019-08-31
  }

  class Patient_D7 as "Patient" <<fixed>> {
    demographics
    comorbidities
    life_status = Alive With Disease (AWD)
    last_check = 2019-08-31
  }
}

' Relationships at Date 7
' DiseaseEvolution1 --> CancerCondition_D7 : target
' DiseaseEvolution1 --> Patient_D7 : affects

package drugTreatment as "Drug Treatment" {

' ===========================================
'Date 8 – 2019-09-10 (Drug treatment start)
' ===========================================
package date8 as "Date 8 (2019-09-10)\nDrug Treatment Start" {
  class DrugAdministration_Start as "Drug Administration" {
    intent = definitive
    start_date = 2019-09-10
  }
}

' ===========================================
'Date 9 – 2019-12-16 (Drug treatment end)
' ===========================================
package date9 as "Date 9 (2019-12-16)\nDrug Treatment End" {
  class DrugAdministration_End as "Drug Administration (end)" {
    intent = definitive
    end_date = 2019-12-16
  }
}

}

'Date7 -[hidden]-> drugTreatment


' Treatment is based on the recurrence and patient status
drugTreatment --> DiseaseEvolution1 : related to

 '/
@enduml
