@startuml
title Cancer data evolution - Evidence + Follow-up Visits (Complete Remission) (Date 5 - 6)

skinparam class {
  BackgroundColor White
}
scale 0.8

package "Date 0 (2018-05-01)\nCancer Condition Diagnosis" {
  class CancerPatient1 <<fixed>> {
    demographics
    comorbiditiesAtDiagnosis
  }
  
  class CancerConditionAtDiagnosis1 <<fixed>> {
    tumourGrade = XXX
    histologyBehaviour = XXX
    bodySite = XXX
    visitDate 
    biopsyDate 
    labReportDate[biomarker] 
    ImagingDate = 2018-05-01 'Date 0
  }
 
}

' Links inside Date 0
CancerPatient1 --> CancerConditionAtDiagnosis1 : is affected by

 package "Date 5 (2019-02-28) \nEvidence + Follow-up (Complete Remission)" {
    
    class LastFollowUp2 {
     vitalStatus = Alive
     evidenceOfDisease = No
     causeOfDeath = Null
     deathDate = Null
     date = 2019-02-28   'Date 5
  }

    class ClinicalCancerProgression2 {
      diseaseStatus = Complete Remission
      extentType = Null
      loco-regionalSite = Null
      MetastaticSite = Null
      tumourGrade
      assertedDate = 2019-02-28   'Date 5
    }

 }

CancerPatient1 --> LastFollowUp2 : has
CancerConditionAtDiagnosis1 --> ClinicalCancerProgression2 : evolves throught

package "Date 6 (2019-05-30) \nEvidence + Follow-up (Complete Remission)" {
    
    class LastFollowUp3 {
     vitalStatus = Alive
     evidenceOfDisease = No
     causeOfDeath = Null
     deathDate = Null
     date = 2019-05-30   'Date 6
  }

    class ClinicalCancerProgression3 {
      diseaseStatus = Complete Remission
      extentType = Null
      loco-regionalSite = Null
      MetastaticSite = Null
      tumourGrade
      assertedDate = 2019-05-30   'Date 6
    }

 }

CancerPatient1 --> LastFollowUp3 : has
CancerConditionAtDiagnosis1 --> ClinicalCancerProgression3 : evolves throught

/' ' ===========================================
' DATE 5 – 2019-02-28 (evidence + follow-up)
' ===========================================
package "Date 5 (2019-02-28)\nEvidence + Follow-up Visit" {
  class CancerCondition_D5 as "Cancer Condition" {
    histology_behaviour (fixed)
    body_site (fixed)
    tumour_grade
    asserted_date = procedure date (fixed)
    base_of_diagnosis (fixed)
    imaging_type (fixed)
    biomarker_type (fixed)
    disease_status = Complete Remission
    last_check = 2019-02-28
  }

  class Patient_D5 as "Patient" <<fixed>> {
    demographics
    comorbidities
    life_status = Alive, No Evidence of Disease (NED)
    last_check = 2019-02-28
  }
}

' ===========================================
'Date 6 – 2019-05-30 (evidence + follow-up)
' ===========================================
package "Date 6 (2019-05-30)\nEvidence + Follow-up Visit" {
  class CancerCondition_D6 as "Cancer Condition" {
    histology_behaviour (fixed)
    body_site (fixed)
    tumour_grade
    asserted_date = procedure date (fixed)
    base_of_diagnosis (fixed)
    imaging_type (fixed)
    biomarker_type (fixed)
    disease_status = Complete Remission
    last_check = 2019-05-30
  }

  class Patient_D6 as "Patient" <<fixed>> {
    demographics
    comorbidities
    life_status = Alive, No Evidence of Disease (NED)
    last_check = 2019-05-30
  }
} '/
@enduml
