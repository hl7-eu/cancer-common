@startuml
title Cancer data evolution – Evidence + Follow-up Visit (Partial Remission) (Date 10)

left to right direction
skinparam class {
  BackgroundColor White
}

scale 0.8

package "Date 0 (2018-05-01)\nCancer Condition Diagnosis" {
  class CancerPatient1 <<fixed>> {
    demographics
    comorbiditiesAtDiagnosis
  }
  
  class CancerConditionAtDiagnosis1 <<fixed>> {
   tumourGrade = XXX
    histologyBehaviour = XXX
    bodySite = XXX
    visitDate 
    biopsyDate 
    labReportDate[biomarker] 
    ImagingDate = 2018-05-01 'Date 0
  }
 
}

' Links inside Date 0
CancerPatient1 --> CancerConditionAtDiagnosis1 : is affected by

package "Date 7 (2019-08-31) \nEvidence + Follow-up (Recurrence)" {
     class ClinicalCancerProgression4 {
      diseaseStatus = Recurrence
      extentType 
      loco-regionalSite 
      MetastaticSite 
      tumourGrade
      assertedDate = 2019-08-31   'Date 7
    }

 }

  package "Date 10 (2020-01-02) \nEvidence + Follow-up (Partial Remission)" {
    
    class OverallTreatmentResponse2 {
      treatmentResponseType = Partial Remission
      date = 2020-01-02   'Date 10
    }

    class LastFollowUp5 {
     vitalStatus = Alive
     evidenceOfDisease = Yes
     causeOfDeath = Null
     deathDate = Null
     date = 2020-01-02   'Date 10
  }

    class ClinicalCancerProgression5 {
      diseaseStatus = Partial Remission
      extentType 
      loco-regionalSite 
      MetastaticSite 
      tumourGrade
      assertedDate = 2020-01-02   'Date 10
    }

 }

CancerConditionAtDiagnosis1 --> ClinicalCancerProgression4 : evolves throught
CancerConditionAtDiagnosis1 --> OverallTreatmentResponse2 : has
ClinicalCancerProgression4 --> OverallTreatmentResponse2 : has
CancerPatient1 --> LastFollowUp5 : has
CancerConditionAtDiagnosis1 --> ClinicalCancerProgression5 : evolves throught


/' ' =====================================================
'Date 10 – 2020-01-02 (evidence + follow-up visit)
' =====================================================
package "Date 10 (2020-01-02)\nEvidence + Follow-up Visit" {

  class TR2 as "Treatment Response 2" {
    treatment_response_type = Partial Remission
    based_on = latest evidence
    date = 2020-01-02
  }

  class CancerCondition_D10 as "Cancer Condition" {
    histology_behaviour (fixed)
    body_site (fixed)
    tumour_grade
    asserted_date = procedure date (fixed)
    base_of_diagnosis (fixed)
    imaging_type (fixed)
    biomarker_type (fixed)
    disease_status = Partial Remission
    last_check = Date 10
  }

  class DiseaseEvolution1 as "Disease Evolution (over time & space) 1" {
    extent_type = Recurrence
    disease_extent (sites)
    histology_behaviour
    tumour_grade
    base_of_diagnosis
    imaging_type
    biomarker_type
    genomics
    asserted_date = Date 7 (fixed)
  }

  class Patient_D10 as "Patient" <<fixed>> {
    demographics
    comorbidities
    life_status = Alive With Disease (AWD)
    last_check = Date 10
  }
}


package drugTreatment as "Drug Treatment" {

' ===========================================
'Date 8 – 2019-09-10 (Drug treatment start)
' ===========================================
package date8 as "Date 8 (2019-09-10)\nDrug Treatment Start" {
  class DrugAdministration_Start as "Drug Administration" {
    intent = definitive
    start_date = 2019-09-10
  }
}

' ===========================================
'Date 9 – 2019-12-16 (Drug treatment end)
' ===========================================
package date9 as "Date 9 (2019-12-16)\nDrug Treatment End" {
  class DrugAdministration_End as "Drug Administration (end)" {
    intent = definitive
    end_date = 2019-12-16
  }
}

}

